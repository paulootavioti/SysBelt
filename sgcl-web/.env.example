# Copie para ".env.local" para desenvolvimento local, se precisar
# apontar para uma API diferente de http://localhost:3333.
#
# Em produção no Netlify (backend como Netlify Function no mesmo site),
# NÃO defina essa variável — o frontend usa "/api" automaticamente
# (same-origin, resolvido pelo redirect em netlify.toml).
# VITE_API_URL=http://localhost:3333
