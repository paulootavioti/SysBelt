new file mode 100644
index 0000000..0a73d60
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,21 @@
+# Copie este arquivo para ".env" e preencha os valores.
+# Em produção (Netlify), configure essas mesmas variáveis em:
+# Site settings > Environment variables.
+
+# Connection string do Postgres. Para uso com Netlify Functions (serverless),
+# prefira um provedor com pooling embutido (ex.: Neon, endpoint "pooled").
+DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"
+
+# Segredo usado para assinar os tokens JWT. Gere um valor aleatório forte,
+# por exemplo: openssl rand -base64 48
+JWT_SECRET="troque-por-um-valor-aleatorio-forte"
+JWT_EXPIRES_IN="7d"
+
+# Porta local (ignorado no Netlify, que gerencia isso internamente).
+PORT=3333
+
+# Origem(ns) permitidas no CORS, separadas por vírgula.
+# Em produção, se o frontend for servido pelo mesmo domínio Netlify
+# (via /api/* redirect), o CORS praticamente não entra em jogo — mas
+# mantenha configurado para cobrir acessos diretos à function.
+CORS_ORIGIN="http://localhost:5173"
diff --git a/netlify.toml b/netlify.toml
new file mode 100644
index 0000000..9409e31
--- /dev/null
+++ b/netlify.toml
@@ -0,0 +1,25 @@
+[build]
+  command = "npm install && npx prisma generate && cd sgcl-web && npm install && npm run build"
+  publish = "sgcl-web/dist"
+
+[build.environment]
+  NODE_VERSION = "20"
+
+[functions]
+  directory = "netlify/functions"
+  node_bundler = "esbuild"
+
+[functions.api]
+  included_files = ["node_modules/.prisma/client/**"]
+
+# Chamadas de API do frontend vão para /api/*, resolvidas pela function.
+[[redirects]]
+  from = "/api/*"
+  to = "/.netlify/functions/api/:splat"
+  status = 200
+
+# Fallback de SPA: qualquer outra rota cai no index.html (React Router cuida do resto).
+[[redirects]]
+  from = "/*"
+  to = "/index.html"
+  status = 200
